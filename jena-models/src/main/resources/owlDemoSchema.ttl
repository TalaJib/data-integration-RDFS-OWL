@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/> .

:Person a owl:Class .

 :Employee a owl:Class ;
            rdfs:subClassOf  :Person .

 :Person a owl:Class ;
            rdfs:subClassOf  :Human .

 :worksAt a owl:ObjectProperty ;
           rdfs:domain  :Employee ;
           rdfs:range owl:Thing .

:hasEmployee a owl:ObjectProperty ;
             owl:inverseOf :worksAt ;
             rdfs:domain owl:Thing ;
             rdfs:range :Employee .

:isFriendOf a owl:SymmetricProperty ;
            rdfs:domain :Person ;
            rdfs:range :Person .

# classes
:Patient a owl:Class ;
    rdfs:subClassOf :Person .

:MedicalCondition a owl:Class .

:Doctor a owl:Class .

:MedicalMeasurement a owl:Class .

:Device a owl:Class .






# Data Properties (Attributs)
:hasID a owl:DatatypeProperty ;
    rdfs:domain :Person ;
    rdfs:range xsd:string .

:hasName a owl:DatatypeProperty ;
    rdfs:domain :Person ;
    rdfs:range xsd:string .

:hasAge a owl:DatatypeProperty ;
    rdfs:domain :Person ;
    rdfs:range xsd:integer .

:heartRateBPM a owl:DatatypeProperty ;
    rdfs:domain :Patient ;
    rdfs:range xsd:integer .

:stepsTakenToday a owl:DatatypeProperty ;
    rdfs:domain :Patient ;
    rdfs:range xsd:integer .

:bloodSugarLevel a owl:DatatypeProperty ;
    rdfs:domain :Patient ;
    rdfs:range xsd:decimal .

:bloodPressure a owl:DatatypeProperty ;
    rdfs:domain :Patient ;
    rdfs:range xsd:string .

:medicationPrescribed a owl:DatatypeProperty ;
    rdfs:domain :Patient ;
    rdfs:range xsd:string .









# Object Properties (Relations)
:hasCondition a owl:ObjectProperty ;
    rdfs:domain :Patient ;
    rdfs:range :MedicalCondition .

:usesDevice a owl:ObjectProperty ;
    rdfs:domain :Patient ;
    rdfs:range :Device .

:hasPrimaryDoctor a owl:FunctionalProperty, owl:ObjectProperty ;
                  rdfs:domain :Patient ;
                  rdfs:range :Doctor .

:isTreatedBy a owl:ObjectProperty ;
             owl:inverseOf :treats ;
             rdfs:domain :Patient ;
             rdfs:range :Doctor .
             
:treats a owl:ObjectProperty ;
        rdfs:domain :Doctor ;
        rdfs:range :Patient .

:isSuperiorOf a owl:TransitiveProperty, owl:ObjectProperty ;
              rdfs:domain :Employee ;
              rdfs:range :Employee .

